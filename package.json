  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@graphql-mesh/cli": "^0.100.53",
    "@graphql-mesh/graphql": "^0.104.40",
    "@graphql-mesh/openapi": "^0.109.54",
    "@kubernetes/client-node": "^1.4.0",
    "express": "^5.1.0",
    "graphql": "^16.9.0",
    "js-yaml": "^4.1.0"
  }
}
